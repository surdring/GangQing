# GangQing 环境变量示例
 # 用法：复制为 .env.local 并填写真实值

 # 运行环境：dev / prod
 GANGQING_ENV=dev
 # 日志级别：DEBUG / INFO / WARNING / ERROR
 GANGQING_LOG_LEVEL=INFO
 # 日志格式：json / console
 # - json：结构化日志（生产默认推荐）
 # - console：开发调试更易读
 GANGQING_LOG_FORMAT=json

 # API 服务监听地址
 GANGQING_API_HOST=127.0.0.1
 # API 服务监听端口
 GANGQING_API_PORT=8000

 # 结构化日志/审计脱敏：额外敏感 key 片段（逗号分隔，小写比较）
 # 示例："key,access_key,refresh_token"
 GANGQING_REDACTION_SENSITIVE_KEY_FRAGMENTS=

 # 多租户/多项目隔离（强制约束：通过请求头传递）
 # - X-Tenant-Id：租户 ID（必填）
 # - X-Project-Id：项目 ID（涉及资料范围/引用/证据链时必填；当前 PoC API 也要求传入）
 # 示例：
 #   curl -H "X-Tenant-Id: t1" -H "X-Project-Id: p1" ...

 # 隔离策略开关
 # 是否启用隔离（默认 true）
 GANGQING_ISOLATION_ENABLED=true
 # 预留：额外隔离维度（逗号分隔），L1 默认不启用
 GANGQING_ISOLATION_EXTRA_DIMENSIONS=

 # 字段级脱敏策略
 # 默认动作：mask/allow/deny
 GANGQING_MASKING_DEFAULT_ACTION=mask
 # 是否在审计中包含策略命中摘要（默认 true）
 GANGQING_MASKING_AUDIT_INCLUDE_POLICY_HITS=true
 # 是否强制要求提供 masking policy（默认 false；为 true 时缺失策略将启动失败/接口返回 CONTRACT_VIOLATION）
 GANGQING_MASKING_POLICY_REQUIRED=false
 # 脱敏策略 JSON（单行 JSON 字符串）
 GANGQING_MASKING_POLICY_JSON=

 # Guardrail Policy (Task 16)
 # 是否强制要求提供 guardrail policy（默认 false）
GANGQING_GUARDRAIL_POLICY_REQUIRED=false
 # Guardrail policy JSON（单行 JSON 字符串；缺省则使用内置默认规则）
GANGQING_GUARDRAIL_POLICY_JSON=

 # CORS 允许来源（逗号分隔）
 GANGQING_CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

 # JWT 配置
 # JWT 密钥（生产环境必须修改；下方默认值仅用于开发环境）
 # 生成方式：openssl rand -hex 32
 GANGQING_JWT_SECRET=dev-secret-change-me
 # JWT 算法（PoC 默认 HS256；生产建议逐步迁移 RS256/ES256）
 GANGQING_JWT_ALG=HS256
 # JWT 过期小时数
 GANGQING_JWT_EXP_HOURS=8

 # 审计异步写入（默认关闭；开启后会通过线程池异步落库以降低请求阻塞）
 GANGQING_AUDIT_ASYNC_ENABLED=0
 GANGQING_AUDIT_ASYNC_MAX_WORKERS=4

 # 启动时引导创建管理员账号（可选；仅当账号不存在时创建）
 # 注意：生产环境应通过安全方式初始化管理员，不建议长期保留明文密码环境变量。
 GANGQING_BOOTSTRAP_ADMIN_USER_ID=
 GANGQING_BOOTSTRAP_ADMIN_PASSWORD=

 # 启动时引导创建财务账号（可选；仅当账号不存在时创建）
 # 用途：用于 RBAC/审计的最小验证（例如财务角色访问 chat 被拒绝）。
 # 注意：生产环境不建议长期保留明文密码环境变量。
 GANGQING_BOOTSTRAP_FINANCE_USER_ID=
 GANGQING_BOOTSTRAP_FINANCE_PASSWORD=

 # PostgreSQL 连接串（SQLAlchemy URL）
# 示例：postgresql+psycopg://user:password@localhost:5432/gangqing
# 安全要求（T08）：必须使用只读账号（仅授予 SELECT 权限），禁止 INSERT/UPDATE/DELETE/DDL。
 GANGQING_DATABASE_URL=

# Postgres 只读查询工具（T08）默认查询超时（秒）
# Default: 5.0
GANGQING_POSTGRES_TOOL_DEFAULT_TIMEOUT_SECONDS=5.0

# Postgres 只读查询工具（T08）最大允许查询超时（秒）
# Default: 30.0
GANGQING_POSTGRES_TOOL_MAX_TIMEOUT_SECONDS=30.0

# Tool Retry & Backoff (Task 10)
# 工具默认超时（秒）
# Default: 10.0
GANGQING_TOOL_DEFAULT_TIMEOUT_SECONDS=10.0
# 工具最大超时（秒）
# Default: 60.0
GANGQING_TOOL_MAX_TIMEOUT_SECONDS=60.0
# 最大重试次数（失败后最多再试 N 次），硬约束：0..3
# Default: 3
GANGQING_TOOL_MAX_RETRIES=3
# 退避参数（毫秒）
# Default: 200
GANGQING_TOOL_BACKOFF_BASE_MS=200
# Default: 2.0
GANGQING_TOOL_BACKOFF_MULTIPLIER=2.0
# Default: 2000
GANGQING_TOOL_BACKOFF_MAX_MS=2000
# 抖动比例（0..1）
# Default: 0.2
GANGQING_TOOL_BACKOFF_JITTER_RATIO=0.2

# Tool Registry (Task 13.1)
# 工具注册表总开关：true/false
# Default: true
GANGQING_TOOL_REGISTRY_ENABLED=true
# 允许执行的工具白名单（逗号分隔）。为空表示不启用白名单过滤。
GANGQING_TOOL_ENABLED_LIST=
# 禁止执行的工具黑名单（逗号分隔）。
GANGQING_TOOL_DISABLED_LIST=

# 什么时候需要调整重试策略：
# - 上游偶发超时/连接抖动：可将 MAX_RETRIES 调到 1-2，并适当增大 BACKOFF_BASE_MS。
# - 上游限流/过载（429/5xx）：建议增大 BACKOFF_BASE_MS / BACKOFF_MAX_MS，避免雪崩。
# - 交互式链路（需要更快反馈）：可降低 BACKOFF_MAX_MS，减少等待时间。
# 推荐值（经验口径）：
# - 默认：MAX_RETRIES=3, BASE_MS=200, MULTIPLIER=2.0, MAX_MS=2000, JITTER=0.2
# - 低延迟：MAX_RETRIES=1, BASE_MS=100, MAX_MS=300
# - 高波动：MAX_RETRIES=2, BASE_MS=300, MAX_MS=3000

# Contract Validation (Task 9)
# 是否启用严格校验（严格模式下校验失败应阻断输出；默认 false）
# Default: false
GANGQING_CONTRACT_VALIDATION_STRICT=false

# details 中 fieldErrors 最大条目数上限（防止过大返回与敏感泄漏）
# Default: 20
GANGQING_CONTRACT_VALIDATION_MAX_ERRORS=20

# Postgres 工具输出契约违规注入（仅用于契约/冒烟测试）
# 说明：为 1/true/TRUE 时，Postgres 只读工具将返回一个故意不符合 ResultModel 的输出，
#      用于验证统一 runner 的输出契约校验是否能稳定映射为 CONTRACT_VIOLATION。
# Default: 0
GANGQING_FORCE_POSTGRES_TOOL_OUTPUT_CONTRACT_VIOLATION=0

# 健康检查（Postgres 探测）连接超时（秒）
# Default: 2.0
GANGQING_HEALTHCHECK_POSTGRES_CONNECT_TIMEOUT_SECONDS=2.0

# 健康检查响应缓存（秒）
# 说明：用于降低高频探针对依赖的压力。设置为 0 表示不缓存。
# Default: 0
# Recommended: 5-10
GANGQING_HEALTHCHECK_CACHE_TTL_SECONDS=0

 # llama.cpp（健康检查依赖探测）
# base_url 示例：http://127.0.0.1:8080
GANGQING_LLAMACPP_BASE_URL=http://localhost:8080/v1
# llama.cpp 推理调用路径（与 base_url 组合；服务端可能暴露 /models 或 /v1/models，客户端会做兼容尝试）
# Default: /models
GANGQING_LLAMACPP_MODELS_PATH=/models
GANGQING_LLAMACPP_HEALTH_PATH=/health
GANGQING_LLAMACPP_TIMEOUT_SECONDS=1.0
 # llama.cpp API key（可选；如服务端需要鉴权）
GANGQING_LLAMACPP_API_KEY=
 # llama.cpp 并发上限（客户端侧队列/信号量保护；用于避免打爆上游）
 # Default: 4
GANGQING_LLAMACPP_MAX_CONCURRENCY=4
 # Whether to trust environment proxy variables (HTTP_PROXY/HTTPS_PROXY/NO_PROXY) for this probe.
 # Default: false
GANGQING_LLAMACPP_TRUST_ENV=false
 # By default, llama.cpp is NOT a critical dependency, because the system can run with other providers.
GANGQING_LLAMACPP_CRITICAL=false

 # llama.cpp smoke test（失败路径断言，可选）
 # 说明：用于 backend/scripts/llamacpp_smoke_test.py
 # - 若同时提供 FAIL_BASE_URL + FAIL_EXPECTED_CODE，则脚本会额外执行一次失败路径并断言错误码。
 # FAIL_BASE_URL 示例：http://127.0.0.1:9/v1
GANGQING_LLAMACPP_SMOKE_FAIL_BASE_URL=
 # FAIL_EXPECTED_CODE 允许值：UPSTREAM_TIMEOUT / UPSTREAM_UNAVAILABLE / CONTRACT_VIOLATION
GANGQING_LLAMACPP_SMOKE_FAIL_EXPECTED_CODE=

 # Provider（第三方/托管模型）健康检查
 # 说明：当 llama.cpp 未配置或不可用时，服务可通过 Provider 作为模型后端。
 # 只要满足：GANGQING_LLAMACPP_BASE_URL 或 GANGQING_PROVIDER_HEALTHCHECK_URL 至少一个在线即可。
 # healthcheck_url 示例：https://example-provider.internal/health
GANGQING_PROVIDER_HEALTHCHECK_URL=https://example.com/health
GANGQING_PROVIDER_TIMEOUT_SECONDS=1.5
# Provider API key（可选；如健康检查端点需要鉴权）
GANGQING_PROVIDER_API_KEY=

# Provider 推理调用（Task 11：llama.cpp 不可用时后备）
# base_url 示例：https://example-provider.internal/v1
GANGQING_PROVIDER_BASE_URL=
# provider_timeout_seconds 语义：Provider 的端到端超时（当前同时用于健康探针与后备调用）。
# 如需区分健康探针与推理调用超时，请在后续任务中拆分为独立配置项。
# Provider 推理使用的固定模型名（可选；若未配置则不进行推理后备，仅用于 list_models 后备探测）
GANGQING_PROVIDER_MODEL=

# 服务版本信息（用于 /api/v1/health.version）
# 建议由 CI 注入，便于可追溯。
# 示例：
#   export GANGQING_SERVICE_NAME=gangqing-api
#   export GANGQING_BUILD=$CI_PIPELINE_ID
#   export GANGQING_COMMIT=$CI_COMMIT_SHA
GANGQING_SERVICE_NAME=gangqing-api
GANGQING_BUILD=unknown
GANGQING_COMMIT=unknown
# Whether to trust environment proxy variables (HTTP_PROXY/HTTPS_PROXY/NO_PROXY) for this probe.
# Default: false
GANGQING_PROVIDER_TRUST_ENV=false

 # Seed Data (Task 6)
 # 运行 ID（用于冒烟/回归日志关联；不填则脚本自动生成）
 GANGQING_RUN_ID=
 # 种子（默认 42；seed_data_smoke_test 默认 123 可通过参数覆盖）
 GANGQING_SEED=42
 # 多租户/多项目隔离（造数/测试默认 t1/p1）
 GANGQING_TENANT_ID=t1
 GANGQING_PROJECT_ID=p1
 # 起始日期（YYYY-MM-DD，默认 2026-02-01）
 GANGQING_SEED_START_DATE=2026-02-01
 # 天数（默认 14；冒烟脚本默认 3 可通过参数覆盖）
 GANGQING_SEED_DAYS=14
 # 规模参数（默认 equipment=3, materials=3, events_per_day=2, workorders=5）
 GANGQING_SEED_EQUIPMENT_COUNT=3
 GANGQING_SEED_MATERIALS_COUNT=3
 GANGQING_SEED_EVENTS_PER_DAY=2
 GANGQING_SEED_WORKORDERS_COUNT=5
 # 数据集版本（用于可重复运行的清理与定位，默认 v1）
 GANGQING_SEED_DATASET_VERSION=v1
 # 异常/边界样本开关（默认 true）
 GANGQING_SEED_EDGE_MISSING_ENABLED=true
 GANGQING_SEED_EDGE_DELAY_ENABLED=true
 GANGQING_SEED_EDGE_DUPLICATE_ENABLED=true
 GANGQING_SEED_EDGE_EXTREME_ENABLED=true
 # 异常样本数量（默认 missing=1, delay=1, duplicate=2, extreme=1）
 GANGQING_SEED_EDGE_MISSING_COUNT=1
 GANGQING_SEED_EDGE_DELAY_COUNT=1
 GANGQING_SEED_EDGE_DUPLICATE_COUNT=2
 GANGQING_SEED_EDGE_EXTREME_COUNT=1

 # 上传目录（用于静态挂载 /uploads）
 GANGQING_UPLOAD_DIR=backend/uploads

 # 外部 API（可选）
 GEMINI_API_KEY=

 # Data Quality (T3)
 # 期望采样间隔（秒），用于缺失点估算
 GANGQING_DATA_QUALITY_EXPECTED_INTERVAL_SECONDS=60
 # 异常检测方法：zscore / iqr
 GANGQING_DATA_QUALITY_ANOMALY_METHOD=zscore
 # 异常检测 z-score 阈值
 GANGQING_DATA_QUALITY_ANOMALY_Z_THRESHOLD=3.0
 # 异常检测 IQR 倍数（当 method=iqr 时生效）
 GANGQING_DATA_QUALITY_ANOMALY_IQR_MULTIPLIER=1.5
 # 漂移检测最小点数
 GANGQING_DATA_QUALITY_DRIFT_MIN_POINTS=10
 # 评分权重（缺失/异常/漂移/质量码），取值范围 [0,1]
 GANGQING_DATA_QUALITY_MISSING_WEIGHT=0.6
 GANGQING_DATA_QUALITY_ANOMALY_WEIGHT=0.3
 GANGQING_DATA_QUALITY_DRIFT_WEIGHT=0.1
 GANGQING_DATA_QUALITY_QUALITY_CODE_WEIGHT=0.2
 # 质量码的“坏值”集合（逗号分隔，小写比较）
 GANGQING_DATA_QUALITY_QUALITY_CODE_BAD_VALUES=0,bad,invalid,unknown

 # 质量报表缓存（PoC 内存缓存，用于减少重复计算）
 # 是否启用：true/false
 GANGQING_DATA_QUALITY_REPORT_CACHE_ENABLED=true
 # TTL（秒）；设置为 0 表示不缓存
 GANGQING_DATA_QUALITY_REPORT_CACHE_TTL_SECONDS=300

 # Time series alignment (T3)
 # /api/v1/data/timeseries/align 的默认对齐窗口（秒）
 GANGQING_DATA_TIMESERIES_DEFAULT_WINDOW_SECONDS=60

 # Connectors (T3) - 仅用于 PoC 配置展示与健康检查预留，不会发起真实读写
 GANGQING_CONNECTORS_CHECK_TIMEOUT_SECONDS=0.5
